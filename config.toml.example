# --- WOL API Server Configuration ---

# JWT Secret for generating tokens
jwt_secret = "your_random_jwt_secret_here"

# HTTPS Settings
tls_cert_path = "certs/cert.pem"
tls_key_path = "certs/key.pem"
bind_address = "0.0.0.0:8443"
allowed_origin = "https://yourusername.github.io" # Set your Github Pages URL here
# interface = "br-lan" # Optional: network interface to bind for WOL packetsting Magic Packets.
# On OpenWrt, 'br-lan' is the standard bridge for the local network.
interface = "br-lan"

# Authorized Users (Multi-account)
[users]
admin = "supersecretpassword"
user2 = "anotherpassword"

# Devices mapping: "unique_name" = ["MAC_ADDRESS", "IP_ADDRESS", "TIMEOUT_SECS"]
[devices]
gaming_pc = ["AA:BB:CC:DD:EE:FF", "192.168.1.10", "30"]
home_server = ["11:22:33:44:55:66", "192.168.1.20", "60"]
nas = ["00:11:22:33:44:55", "192.168.1.30", "90"]
